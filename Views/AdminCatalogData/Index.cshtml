    document.getElementById('tag-id').value = t.id;
    document.getElementById('tag-slug').value = t.slug;
    document.getElementById('tag-name-ru').value = t.nameRu;
    document.getElementById('tag-name-be').value = t.nameBe || '';
    document.getElementById('tag-name-en').value = t.nameEn || '';
    document.getElementById('tag-color').value = t.colorHex || '#3B5E3F';
    document.getElementById('tag-form-title').textContent = `${i18nCatalog.editPrefix}: ${t.nameRu}`;
    syncTagPreview();
