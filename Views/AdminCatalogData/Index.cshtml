function renderTags() {
    const tbody = document.getElementById('tagTableBody');
    if (!tags.length) {
        tbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted py-3">${i18nCatalog.noRecords}</td></tr>`;
        return;
    }
    tbody.innerHTML = tags.map(t => `
        <tr class="ref-row">
            <td><code style="font-size:.8rem;">${esc(t.slug)}</code></td>
            <td>${esc(t.nameRu)}</td>
            <td>${esc(t.nameBe || '—')}</td>
            <td>${esc(t.nameEn || '—')}</td>
            <td>
                ${t.colorHex ? `<span class="color-dot" style="background:${esc(t.colorHex)}"></span><code style="font-size:.78rem;">${esc(t.colorHex)}</code>` : '—'}
            </td>
