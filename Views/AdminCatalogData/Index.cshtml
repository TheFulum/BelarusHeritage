}

async function saveTag() {
    const err = document.getElementById('tag-error');
    err.style.display = 'none';
    const data = {
        id: parseInt(document.getElementById('tag-id').value),
        slug: document.getElementById('tag-slug').value.trim(),
        nameRu: document.getElementById('tag-name-ru').value.trim(),
        nameBe: document.getElementById('tag-name-be').value.trim(),
        nameEn: document.getElementById('tag-name-en').value.trim(),
        colorHex: document.getElementById('tag-color').value
    };
    if (!data.slug || !data.nameRu) { err.textContent = i18nCatalog.requiredSlugRu; err.style.display = ''; return; }

    const res = await fetch('/AdminCatalogData/SaveTag', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    });
    const json = await res.json();
    if (json.success) {
        resetTagForm();
        loadTags();
    } else {
        err.textContent = json.message || i18nCatalog.saveError;
        err.style.display = '';
    }
}

function deleteTagConfirm(id, name) {
    confirmDelete(i18nCatalog.deleteTagConfirm.replace('{0}', name), async () => {
        await fetch('/AdminCatalogData/DeleteTag', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(id)
        });
        loadTags();
    });
}

