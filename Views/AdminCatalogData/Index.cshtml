// ────────────────────── INIT ──────────────────────
function loadTabData(tab) {
    if (tab === 'categories') loadCategories();
    else if (tab === 'tags') loadTags();
    else if (tab === 'styles') loadStyles();
    else if (tab === 'regions') loadRegions();
}

function esc(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function slugifyRu(v) {
    const translitMap = {
        '\u0430': 'a', '\u0431': 'b', '\u0432': 'v', '\u0433': 'g', '\u0434': 'd', '\u0435': 'e', '\u0451': 'yo',
        '\u0436': 'zh', '\u0437': 'z', '\u0438': 'i', '\u0439': 'y', '\u043a': 'k', '\u043b': 'l', '\u043c': 'm',
        '\u043d': 'n', '\u043e': 'o', '\u043f': 'p', '\u0440': 'r', '\u0441': 's', '\u0442': 't', '\u0443': 'u',
        '\u0444': 'f', '\u0445': 'kh', '\u0446': 'ts', '\u0447': 'ch', '\u0448': 'sh', '\u0449': 'sch', '\u044a': '',
        '\u044b': 'y', '\u044c': '', '\u044d': 'e', '\u044e': 'yu', '\u044f': 'ya'
    };
    return (v || '')
        .toLowerCase()
        .replace(/['"`]/g, '')
        .replace(/\s+/g, '-')
        .split('').map(ch => translitMap[ch] ?? ch).join('')
        .replace(/[^a-z0-9-]/g, '')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');
}

function syncCategoryPreview() {
    const icon = document.getElementById('cat-icon').value.trim() || 'bi bi-building';
    const color = document.getElementById('cat-color').value || '#8B1A2A';
    document.getElementById('cat-icon-preview').innerHTML = `<i class="${esc(icon)}"></i> ${esc(icon)}`;
    document.getElementById('cat-color-preview').style.background = color;
    document.getElementById('cat-color-text').textContent = color.toUpperCase();
}

function syncTagPreview() {
    const color = document.getElementById('tag-color').value || '#3B5E3F';
    document.getElementById('tag-color-preview').style.background = color;
    document.getElementById('tag-color-text').textContent = color.toUpperCase();
}

document.getElementById('cat-name-ru').addEventListener('input', () => {
    const slugEl = document.getElementById('cat-slug');
    if (!slugEl.value.trim()) slugEl.value = slugifyRu(document.getElementById('cat-name-ru').value);
});
document.getElementById('tag-name-ru').addEventListener('input', () => {
    const slugEl = document.getElementById('tag-slug');
    if (!slugEl.value.trim()) slugEl.value = slugifyRu(document.getElementById('tag-name-ru').value);
});
document.getElementById('style-name-ru').addEventListener('input', () => {
    const slugEl = document.getElementById('style-slug');
    if (!slugEl.value.trim()) slugEl.value = slugifyRu(document.getElementById('style-name-ru').value);
});
document.getElementById('cat-color').addEventListener('input', syncCategoryPreview);
document.getElementById('cat-icon').addEventListener('input', syncCategoryPreview);
document.getElementById('tag-color').addEventListener('input', syncTagPreview);
syncCategoryPreview();
syncTagPreview();

// Load default tab
loadCategories();
</script>
