function resetTagForm() {
    ['tag-id','tag-slug','tag-name-ru','tag-name-be','tag-name-en'].forEach(id => {
        document.getElementById(id).value = id === 'tag-id' ? '0' : '';
    });
    document.getElementById('tag-color').value = '#3B5E3F';
