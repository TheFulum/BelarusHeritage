<script>
(() => {
    const wrap = document.getElementById('heroFloatingIcons');
    if (!wrap) return;

    const icons = [
        'bi-bank', 'bi-building', 'bi-building-check', 'bi-geo-alt', 'bi-geo',
        'bi-map', 'bi-map-fill', 'bi-pin-map', 'bi-signpost-2', 'bi-compass',
        'bi-tree', 'bi-camera', 'bi-bricks', 'bi-hourglass-split', 'bi-award',
        'bi-stars', 'bi-bookmark-star', 'bi-globe2', 'bi-binoculars', 'bi-shop-window'
    ];

    const maxAlive = window.matchMedia('(max-width: 768px)').matches ? 34 : 62;
    let alive = 0;

    function spawnIcon() {
        if (alive >= maxAlive) return;
        const el = document.createElement('i');
        el.className = `bi ${icons[Math.floor(Math.random() * icons.length)]} hero-float`;
        el.style.setProperty('--x', `${Math.random() * 100}%`);
        // Start below bottom edge so icons visibly rise from the very bottom.
        el.style.setProperty('--y', `${100 + Math.random() * 14}%`);
        el.style.setProperty('--size', `${1 + Math.random() * 2.2}rem`);
        const dur = 10 + Math.random() * 22;
        el.style.setProperty('--dur', `${dur.toFixed(2)}s`);
        el.style.setProperty('--drift', `${(-40 + Math.random() * 80).toFixed(0)}px`);
        el.style.setProperty('--alpha', `${(0.08 + Math.random() * 0.18).toFixed(2)}`);
        alive += 1;
        el.addEventListener('animationend', () => {
            el.remove();
            alive = Math.max(0, alive - 1);
        });
        wrap.appendChild(el);
    }

    // Tiny warm-up so screen is not empty, but without one big "wave".
    const initial = Math.floor(maxAlive * 0.12);
    for (let i = 0; i < initial; i++) {
        setTimeout(spawnIcon, Math.random() * 700);
    }

    function scheduleNextSpawn() {
        spawnIcon();
        const nextIn = 120 + Math.random() * 360;
        setTimeout(scheduleNextSpawn, nextIn);
    }
    setTimeout(scheduleNextSpawn, 60);
})();
</script>

@* localization is centralized in BelarusHeritage.Localization.UiText *@
@functions {
    private string GetQuizTypeName(BelarusHeritage.Models.Domain.QuizType type)
    {
        return type switch
        {
            BelarusHeritage.Models.Domain.QuizType.ImageGuess => BelarusHeritage.Localization.UiText.T(Context, $"home.quizType.imageGuess"),
            BelarusHeritage.Models.Domain.QuizType.RegionGuess => BelarusHeritage.Localization.UiText.T(Context, $"home.quizType.regionGuess"),
            BelarusHeritage.Models.Domain.QuizType.DragDrop => BelarusHeritage.Localization.UiText.T(Context, $"home.quizType.dragDrop"),
            BelarusHeritage.Models.Domain.QuizType.CenturyGuess => BelarusHeritage.Localization.UiText.T(Context, $"home.quizType.centuryGuess"),
            BelarusHeritage.Models.Domain.QuizType.OddOneOut => BelarusHeritage.Localization.UiText.T(Context, $"home.quizType.oddOneOut"),
            _ => type.ToString()
        };
    }

    private string NormalizeImageUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return "";
        url = url.Replace('\\', '/');
        if (url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            url.StartsWith("https://", StringComparison.OrdinalIgnoreCase) ||
            url.StartsWith("/", StringComparison.Ordinal))
            return url;
        return "/" + url;
    }
}
