@using BelarusHeritage.Localization
<!DOCTYPE html>
<html lang="@(UiText.Lang(Context))">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — @UiText.T(Context, "admin.layout.panel")</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="~/lib/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --admin-sidebar-width: 260px;
            --admin-sidebar-bg: #1a1f2e;
            --admin-sidebar-hover: #2d3348;
            --admin-sidebar-active: #8B1A2A;
            --admin-sidebar-text: #b8bcc8;
            --admin-sidebar-text-active: #fff;
            --admin-topbar-height: 58px;
            --admin-content-bg: #f4f6f9;
        }

        * { box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--admin-content-bg);
            margin: 0;
            min-height: 100vh;
        }

        /* Sidebar */
        .admin-sidebar {
            position: fixed;
            top: 0; left: 0; bottom: 0;
            width: var(--admin-sidebar-width);
            background: var(--admin-sidebar-bg);
            display: flex;
            flex-direction: column;
            z-index: 1000;
            overflow-y: auto;
        }
        .admin-sidebar-brand {
            padding: 20px 20px 16px;
            border-bottom: 1px solid rgba(255,255,255,.08);
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }
        .admin-sidebar-brand-icon {
            width: 36px; height: 36px;
            background: var(--admin-sidebar-active);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 18px; color: #fff;
            flex-shrink: 0;
        }
        .admin-sidebar-brand-text {
            color: #fff;
            font-size: .9rem;
            font-weight: 600;
            line-height: 1.3;
        }
        .admin-sidebar-brand-sub {
            font-size: .7rem;
            color: var(--admin-sidebar-text);
            font-weight: 400;
        }
        .admin-nav { padding: 12px 0; flex: 1; }
        .admin-nav-section {
            padding: 8px 20px 4px;
            font-size: .65rem;
            font-weight: 600;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: #586074;
        }
        .admin-nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 20px;
            color: var(--admin-sidebar-text);
            text-decoration: none;
            font-size: .875rem;
            font-weight: 400;
            transition: all .15s;
            border-radius: 0;
        }
        .admin-nav-link:hover {
            background: var(--admin-sidebar-hover);
            color: var(--admin-sidebar-text-active);
        }
        .admin-nav-link.active {
            background: var(--admin-sidebar-active);
            color: var(--admin-sidebar-text-active);
            font-weight: 500;
        }
        .admin-nav-link .badge {
            margin-left: auto;
            font-size: .65rem;
        }
        .admin-sidebar-footer {
            padding: 12px 20px;
            border-top: 1px solid rgba(255,255,255,.08);
        }
        .admin-sidebar-footer a {
            color: var(--admin-sidebar-text);
            font-size: .8rem;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .admin-sidebar-footer a:hover { color: #fff; }

        /* Topbar */
        .admin-topbar {
            position: fixed;
            top: 0;
            left: var(--admin-sidebar-width);
            right: 0;
            height: var(--admin-topbar-height);
            background: #fff;
            border-bottom: 1px solid #e5e9f0;
            display: flex;
            align-items: center;
            padding: 0 24px;
            gap: 16px;
            z-index: 999;
        }
        .admin-topbar-title {
            font-size: 1rem;
            font-weight: 600;
            color: #1a1f2e;
            flex: 1;
        }
        .admin-topbar-user {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: .85rem;
            color: #4a5568;
        }
        .admin-topbar-avatar {
            width: 32px; height: 32px;
            background: #8B1A2A;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: #fff;
            font-size: .75rem;
            font-weight: 600;
        }

        /* Main content */
        .admin-main {
            margin-left: var(--admin-sidebar-width);
            padding-top: var(--admin-topbar-height);
            min-height: 100vh;
        }
        .admin-content {
            padding: 40px 28px 40px;
        }
        .admin-page-header {
            margin-bottom: 24px;
        }
        .admin-page-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #1a1f2e;
            margin: 0 0 4px;
        }
        .admin-page-breadcrumb {
            font-size: .8rem;
            color: #6b7280;
        }
        .admin-page-breadcrumb a {
            color: #8B1A2A;
            text-decoration: none;
        }
        .admin-page-breadcrumb a:hover { text-decoration: underline; }
        .admin-page-breadcrumb .sep { margin: 0 6px; }

        /* Cards */
        .admin-card {
            background: #fff;
            border-radius: 10px;
            border: 1px solid #e5e9f0;
            box-shadow: 0 1px 3px rgba(0,0,0,.04);
            overflow: hidden;
        }
        .admin-card-header {
            padding: 16px 20px;
            border-bottom: 1px solid #e5e9f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .admin-card-title {
            font-size: .95rem;
            font-weight: 600;
            color: #1a1f2e;
            margin: 0;
        }
        .admin-card-body { padding: 20px; }

        /* Tables */
        .admin-table { margin: 0; }
        .admin-table thead th {
            background: #f8fafc;
            border-top: none;
            border-bottom: 2px solid #e5e9f0;
            font-size: .75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: #6b7280;
            padding: 10px 16px;
        }
        .admin-table tbody td {
            padding: 12px 16px;
            vertical-align: middle;
            border-color: #f0f3f7;
            font-size: .875rem;
        }
        .admin-table tbody tr:hover { background: #fafbfd; }

        /* Stat cards */
        .stat-card {
            background: #fff;
            border-radius: 10px;
            border: 1px solid #e5e9f0;
            padding: 20px;
            display: flex;
            align-items: flex-start;
            gap: 16px;
            height: 100%;
        }
        .stat-card-icon {
            width: 48px; height: 48px;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 22px;
            flex-shrink: 0;
        }
        .stat-card-value {
            font-size: 1.6rem;
            font-weight: 700;
            color: #1a1f2e;
            line-height: 1;
        }
        .stat-card-label {
            font-size: .78rem;
            color: #6b7280;
            margin-top: 3px;
        }

        /* Alerts */
        .admin-alert { border-radius: 8px; border: none; font-size: .875rem; }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- Sidebar -->
<nav class="admin-sidebar">
    <a href="/AdminDashboard" class="admin-sidebar-brand">
        <div class="admin-sidebar-brand-icon">
            <i class="bi bi-shield-check"></i>
        </div>
        <div>
            <div class="admin-sidebar-brand-text">@UiText.T(Context, "admin.layout.brand")</div>
            <div class="admin-sidebar-brand-sub">@UiText.T(Context, "admin.layout.panel")</div>
        </div>
    </a>

    <nav class="admin-nav">
        <span class="admin-nav-section">@UiText.T(Context, "admin.section.overview")</span>
        <a href="/AdminDashboard" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminDashboard" ? "active" : "")">
            <i class="bi bi-speedometer2"></i> @UiText.T(Context, "admin.nav.dashboard")
        </a>

        <span class="admin-nav-section">@UiText.T(Context, "admin.section.content")</span>
        <a href="/AdminObjects" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminObjects" ? "active" : "")">
            <i class="bi bi-building"></i> @UiText.T(Context, "admin.nav.objects")
        </a>
        <a href="/AdminTimeline" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminTimeline" ? "active" : "")">
            <i class="bi bi-calendar-event"></i> @UiText.T(Context, "admin.nav.timeline")
        </a>
        <a href="/AdminQuizzes" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminQuizzes" ? "active" : "")">
            <i class="bi bi-patch-question"></i> @UiText.T(Context, "admin.nav.quizzes")
        </a>

        <span class="admin-nav-section">@UiText.T(Context, "admin.section.moderation")</span>
        <a href="/AdminComments" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminComments" ? "active" : "")">
            <i class="bi bi-chat-dots"></i> @UiText.T(Context, "admin.nav.comments")
            @if (ViewBag.PendingComments is int pc && pc > 0)
            {
                <span class="badge bg-danger">@pc</span>
            }
        </a>
        <a href="/AdminOrnaments" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminOrnaments" ? "active" : "")">
            <i class="bi bi-grid-3x3-gap"></i> @UiText.T(Context, "admin.nav.ornaments")
        </a>
        <a href="/AdminTrash" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminTrash" ? "active" : "")">
            <i class="bi bi-trash3"></i> @UiText.T(Context, "admin.nav.trash")
        </a>

        <span class="admin-nav-section">@UiText.T(Context, "admin.section.administration")</span>
        <a href="/AdminUsers" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminUsers" ? "active" : "")">
            <i class="bi bi-people"></i> @UiText.T(Context, "admin.nav.users")
        </a>
        <a href="/AdminCatalogData" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminCatalogData" ? "active" : "")">
            <i class="bi bi-tags"></i> @UiText.T(Context, "admin.nav.catalogData")
        </a>
        <a href="/AdminAuditLog" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminAuditLog" ? "active" : "")">
            <i class="bi bi-journal-text"></i> @UiText.T(Context, "admin.nav.auditLog")
        </a>
        <a href="/AdminSettings/SocialLinks" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminSettings" ? "active" : "")">
            <i class="bi bi-share"></i> @UiText.T(Context, "admin.nav.social")
        </a>
    </nav>

    <div class="admin-sidebar-footer">
        <a href="/" target="_blank">
            <i class="bi bi-box-arrow-up-right"></i> @UiText.T(Context, "admin.openSite")
        </a>
    </div>
</nav>

<!-- Topbar -->
<header class="admin-topbar">
    <span class="admin-topbar-title">@(ViewData["Title"] ?? UiText.T(Context, "admin.layout.controlPanel"))</span>

    <div class="admin-topbar-user">
        <div class="admin-topbar-avatar">
            @{ var uname = User.Identity?.Name ?? "A"; }
            @uname.Substring(0, 1).ToUpper()
        </div>
        <span>@User.Identity?.Name</span>
        <a href="/Auth/Logout" class="ms-2 text-danger" style="font-size:.8rem;">
            <i class="bi bi-box-arrow-right"></i>
        </a>
    </div>
</header>

<!-- Main -->
<main class="admin-main">
    <div class="admin-content">
        @RenderBody()
    </div>
</main>

<!-- Toast Container -->
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999">
    <div id="adminToast" class="toast align-items-center border-0 text-white" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="adminToastBody"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<!-- Confirm Modal -->
<div class="modal fade" id="adminConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title mb-0">@UiText.T(Context, "meta.confirmTitle")</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="adminConfirmMessage"></div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">@UiText.T(Context, "btn.cancel")</button>
                <button type="button" class="btn btn-sm btn-danger" id="adminConfirmOk">@UiText.T(Context, "btn.confirm")</button>
            </div>
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function showToast(message, type) {
        const el = document.getElementById('adminToast');
        el.className = 'toast align-items-center border-0 text-white bg-' + (type === 'success' ? 'success' : type === 'warning' ? 'warning' : 'danger');
        document.getElementById('adminToastBody').textContent = message;
        new bootstrap.Toast(el, { delay: 3500 }).show();
    }
    let _confirmCb = null;
    function showConfirm(message, onConfirm, confirmLabel) {
        document.getElementById('adminConfirmMessage').textContent = message;
        document.getElementById('adminConfirmOk').textContent = confirmLabel || '@UiText.T(Context, "btn.confirm")';
        _confirmCb = onConfirm;
        new bootstrap.Modal(document.getElementById('adminConfirmModal')).show();
    }
    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('adminConfirmOk').addEventListener('click', () => {
            bootstrap.Modal.getInstance(document.getElementById('adminConfirmModal'))?.hide();
            if (_confirmCb) { _confirmCb(); _confirmCb = null; }
        });
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
