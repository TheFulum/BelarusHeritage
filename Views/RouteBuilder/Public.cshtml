@model List<BelarusHeritage.Models.Domain.Route>
@{
    var lang = BelarusHeritage.Localization.UiText.Lang(Context);
    string L(string key) => BelarusHeritage.Localization.UiText.T(Context, $"route.public.{key}");
    ViewData["Title"] = L("title");
}

<section class="py-4 route-public-page">
    <div class="container">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
            <h1 class="h4 mb-0">@L("title")</h1>
            <a href="@Url.Action("Index", "RouteBuilder")" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-plus-circle me-1"></i> @L("btn.create")
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-light border mb-0">@L("empty")</div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var route in Model)
                {
                    var stops = route.Stops?.Count ?? 0;
                    var cover = route.Stops?
                        .OrderBy(s => s.SortOrder)
                        .Select(s => s.Object)
                        .Where(o => o != null)
                        .Select(o => o!.Images?.FirstOrDefault(i => i.IsMain)?.Url
                                     ?? o.Images?.FirstOrDefault(i => i.IsMain)?.ThumbUrl
                                     ?? o.MainImageUrl)
                        .FirstOrDefault(x => !string.IsNullOrWhiteSpace(x));
                    cover = NormalizeImageUrl(cover);
                    <div class="col-12 col-md-6 col-xl-4">
                        <article class="route-public-card">
                            <a class="route-public-cover" href="@Url.Action("Share", "RouteBuilder", new { token = route.ShareToken })">
                                @if (!string.IsNullOrWhiteSpace(cover))
                                {
                                    <img src="@cover" alt="@route.Title" loading="lazy">
                                }
                                else
                                {
                                    <div class="route-public-cover-placeholder"><i class="bi bi-image"></i></div>
                                }
                                <div class="route-public-cover-overlay"></div>
                                <div class="route-public-cover-chips">
                                    <span class="chip"><i class="bi bi-geo-alt"></i> @stops</span>
                                    @if (route.TotalKm.HasValue)
                                    {
                                        <span class="chip"><i class="bi bi-rulers"></i> @route.TotalKm.Value.ToString("F1") @L("meta.km")</span>
                                    }
                                    <span class="chip"><i class="bi bi-calendar3"></i> @route.UpdatedAt.ToLocalTime().ToString("dd.MM.yyyy")</span>
                                </div>
                            </a>

                            <div class="route-public-body">
                                <div class="route-public-title" title="@route.Title">@route.Title</div>
                                <div class="route-public-meta">
                                    <span class="meta-item"><i class="bi bi-person"></i> @(route.User?.DisplayName ?? route.User?.UserName ?? L("user.default"))</span>
                                    <span class="meta-item"><i class="bi bi-signpost-2"></i> @L("meta.route")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(route.Description))
                                {
                                    <div class="route-public-desc">@route.Description</div>
                                }
                                else
                                {
                                    <div class="route-public-desc is-muted">@L("desc.empty")</div>
                                }
                                <div class="route-public-actions">
                                    <a href="@Url.Action("Share", "RouteBuilder", new { token = route.ShareToken })" class="btn btn-primary btn-sm">
                                        <i class="bi bi-arrow-right-circle me-1"></i> @L("btn.open")
                                    </a>
                                    <a href="@Url.Action("Share", "RouteBuilder", new { token = route.ShareToken })" class="btn btn-outline-secondary btn-sm" title="@L("btn.openNewTab")" target="_blank">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </a>
                                </div>
                            </div>
                        </article>
                    </div>
                }
            </div>
        }
    </div>
</section>

<style>
    .route-public-page {
        background: linear-gradient(180deg, #f9f4eb 0%, #fff 40%);
    }
    .route-public-card {
        border: 1px solid #ece5d9;
        border-radius: 16px;
        background: rgba(255,255,255,.92);
        box-shadow: 0 14px 34px rgba(17,24,39,.08);
        overflow: hidden;
        transition: transform 180ms ease-out, box-shadow 180ms ease-out;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .route-public-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 20px 46px rgba(17,24,39,.12);
    }

    .route-public-cover {
        position: relative;
        display: block;
        aspect-ratio: 16 / 10;
        background: #f4f0ea;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
    }
    .route-public-cover img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transform: scale(1.02);
        transition: transform 220ms cubic-bezier(0.23, 1, 0.32, 1);
    }
    .route-public-card:hover .route-public-cover img { transform: scale(1.07); }
    .route-public-cover-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(0,0,0,.0) 0%, rgba(0,0,0,.58) 100%);
        pointer-events: none;
    }
    .route-public-cover-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
        font-size: 2rem;
    }
    .route-public-cover-chips {
        position: absolute;
        left: 12px;
        bottom: 12px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        z-index: 2;
    }
    .route-public-cover-chips .chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 26px;
        padding: 0 10px;
        border-radius: 999px;
        background: rgba(255,255,255,.92);
        color: #111827;
        font-size: .78rem;
        font-weight: 800;
        box-shadow: 0 16px 30px rgba(0,0,0,.18);
    }

    .route-public-body {
        padding: 12px 13px 14px;
        display: flex;
        flex-direction: column;
        flex: 1 1 auto;
    }
    .route-public-title {
        font-weight: 800;
        color: #111827;
        line-height: 1.25;
        margin-bottom: 6px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 2.5em;
    }
    .route-public-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        color: #6b7280;
        font-size: .82rem;
        margin-bottom: 10px;
    }
    .route-public-meta .meta-item { display: inline-flex; align-items: center; gap: 6px; }
    .route-public-desc {
        color: #374151;
        font-size: .9rem;
        line-height: 1.55;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 12px;
        flex: 1 1 auto;
    }
    .route-public-desc.is-muted { color: #6b7280; }
    .route-public-actions { display:flex; gap: 8px; align-items: center; }

    @@media (max-width: 575.98px) {
        .route-public-cover-chips { left: 10px; bottom: 10px; }
    }
</style>

@functions {
    private string NormalizeImageUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return "";
        url = url.Replace('\\', '/');
        if (url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            url.StartsWith("https://", StringComparison.OrdinalIgnoreCase) ||
            url.StartsWith("/", StringComparison.Ordinal))
            return url;
        return "/" + url;
    }
}
