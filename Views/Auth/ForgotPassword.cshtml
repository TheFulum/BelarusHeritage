@{
    ViewData["Title"] = Localize("title");
}

@section Styles {
    <link href="~/css/pages/auth.css" rel="stylesheet">
}

<section class="auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="auth-card" data-aos="fade-up">
                    <div class="auth-header">
                        <h1 class="auth-title">@Localize("title")</h1>
                        <p class="auth-subtitle">@Localize("subtitle")</p>
                    </div>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                    }

                    <form asp-action="ForgotPassword" method="post" class="auth-form">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <div asp-validation-summary="All"></div>
                            </div>
                        }

                        <div class="form-floating mb-3">
                            <input type="email" class="form-control" id="email" name="email"
                                   placeholder="name@example.com" required autofocus>
                            <label for="email">@Localize("email")</label>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">
                            <i class="bi bi-envelope-arrow-up me-2"></i>
                            @Localize("sendBtn")
                        </button>

                        <div class="auth-links">
                            <a href="@Url.Action("Login", "Auth")" class="auth-link">
                                @Localize("backToLogin")
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@functions {
    private string Localize(string key)
    {
        return BelarusHeritage.Localization.UiText.T(Context, $"auth.forgot.{key}");
    }
}
