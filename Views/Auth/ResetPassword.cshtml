@{
    ViewData["Title"] = Localize("title");
    var token = ViewBag.Token as string;
}

@section Styles {
    <link href="~/css/pages/auth.css" rel="stylesheet">
}

<section class="auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="auth-card" data-aos="fade-up">
                    <div class="auth-header">
                        <h1 class="auth-title">@Localize("title")</h1>
                        <p class="auth-subtitle">@Localize("subtitle")</p>
                    </div>

                    <form asp-action="ResetPassword" method="post" class="auth-form">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <div asp-validation-summary="All"></div>
                            </div>
                        }

                        <input type="hidden" name="token" value="@token" />

                        <div class="form-floating mb-3">
                            <input type="password" class="form-control" id="password" name="password"
                                   placeholder="New password" minlength="6" required autofocus>
                            <label for="password">@Localize("password")</label>
                        </div>

                        <div class="form-floating mb-2">
                            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword"
                                   placeholder="Repeat" minlength="6" required>
                            <label for="confirmPassword">@Localize("confirm")</label>
                        </div>

                        <div class="form-text mb-3">@Localize("passwordHint")</div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">
                            <i class="bi bi-shield-lock me-2"></i>
                            @Localize("submitBtn")
                        </button>

                        <div class="auth-links">
                            <a href="@Url.Action("Login", "Auth")" class="auth-link">
                                @Localize("backToLogin")
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@functions {
    private string Localize(string key)
    {
        return BelarusHeritage.Localization.UiText.T(Context, $"auth.reset.{key}");
    }
}
