@{
    ViewData["Title"] = Localize("title");
    var returnUrl = ViewBag.ReturnUrl as string;
}

@section Styles {
    <link href="~/css/pages/auth.css" rel="stylesheet">
}

<section class="auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="auth-card" data-aos="fade-up">
                    <div class="auth-header">
                        <h1 class="auth-title">@Localize("title")</h1>
                        <p class="auth-subtitle">@Localize("subtitle")</p>
                    </div>

                    <partial name="_AuthAlerts" />

                    <form asp-action="Login" method="post" class="auth-form">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="returnUrl" value="@returnUrl" />

                        <div class="form-floating mb-3">
                            <input type="email" class="form-control" id="email" name="email"
                                   placeholder="name@example.com" required autofocus>
                            <label for="email">@Localize("email")</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input type="password" class="form-control" id="password" name="password"
                                   placeholder="Password" required>
                            <label for="password">@Localize("password")</label>
                        </div>

                        <div class="form-check mb-3">
                            <input type="checkbox" class="form-check-input" id="rememberMe" name="rememberMe" value="true">
                            <label class="form-check-label" for="rememberMe">@Localize("rememberMe")</label>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">
                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            @Localize("loginBtn")
                        </button>

                        <div class="auth-links">
                            @if (FeatureFlags.PasswordRecovery)
                            {
                                <a href="@Url.Action("ForgotPassword", "Auth")" class="auth-link">
                                    @Localize("forgotPassword")
                                </a>
                                <span class="auth-divider">·</span>
                            }
                            <a href="@Url.Action("Register", "Auth")" class="auth-link">
                                @Localize("noAccount")
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@functions {
    private string Localize(string key)
    {
        return BelarusHeritage.Localization.UiText.T(Context, $"auth.login.{key}");
    }
}
